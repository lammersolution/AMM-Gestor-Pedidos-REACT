# ── Banco de Dados Firebird ────────────────────────────────
DB_HOST=localhost
DB_PORT=3050
DB_DATABASE=C:\Lammer\Dados\DADOS.ARMARINHOJULIANA.FDB
DB_USER=SYSDBA
DB_PASSWORD=masterkey
DB_POOL_MAX=10

# ── Sessão ─────────────────────────────────────────────────
# IMPORTANTE: gere uma chave aleatória longa para produção
# Ex: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=MUDE_PARA_UMA_CHAVE_ALEATORIA_LONGA
SESSION_LIFETIME_HOURS=10

# ── Servidor ───────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── CORS ───────────────────────────────────────────────────
# Deixe em branco para aceitar qualquer IP da rede local (recomendado para LAN)
# Ou defina o IP fixo do servidor: http://192.168.1.100:5173
FRONTEND_URL=
